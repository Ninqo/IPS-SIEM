# Blocage Scan Nmap
drop tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"[SENTINEL] Nmap Scan Detected"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:1000002; rev:1;)

# Blocage Brute Force SSH
drop tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"[SENTINEL] SSH Brute Force Attempt"; flow:established,to_server; detection_filter:track by_src, count 5, seconds 60; sid:1000003; rev:1;)

#Alerte si ping sur le reseau
alert icmp any any -> any any (msg:"ICMP Ping detecte";sid:1000001; rev:1;)

#Alerte si tentative de connexion au port TCP 80
alert tcp any any -> any 80 (msg:"Connexion au port 80 detecte";sid:1000004; rev:1;)